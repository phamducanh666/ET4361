/**
 * Hàm so sánh tùy chỉnh cho qsort
 */
int compare_fields(const void *v1, const void *v2) {
    char *s1 = *(char **)v1;
    char *s2 = *(char **)v2;
    
    for (int i = 0; i < num_fields; i++) {
        char f1[100], f2[100];
        get_field(f1, s1, i);
        get_field(f2, s2, i);
        
        int res;
        if (options[i].numeric) {
            double n1 = atof(f1);
            double n2 = atof(f2);
            res = (n1 > n2) - (n1 < n2);
        } else {
            // Sử dụng logic so sánh chuỗi với -d, -f
            res = strcmp(f1, f2); 
        }
        
        if (res != 0) {
            return options[i].reverse ? -res : res;
        }
    }
    return 0;
}
